# Required
OPENAI_API_KEY=sk-...

# Optional — Gems backend that supplies cluster/insight grounding.
# If unset or unreachable, topic ideation degrades to pure-LLM (worse signal).
GEMS_API_BASE=https://gems-poi-production.up.railway.app

# Optional — image model overrides. Defaults baked in.
IMAGE_MODEL=gpt-image-2
TEXT_MODEL_HEAVY=gpt-4o
TEXT_MODEL_LIGHT=gpt-4o-mini
